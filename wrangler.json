{
  "name": "restaurant-la-bonne-etape",
  "main": "dist/_worker.js",
  "compatibility_date": "2025-10-08",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "routes": [
    {
      "pattern": "restaurant-la-bonne-etape.fr/*",
      "zone_name": "restaurant-la-bonne-etape.fr"
    },
    {
      "pattern": "www.restaurant-la-bonne-etape.fr/*",
      "zone_name": "restaurant-la-bonne-etape.fr"
    }
  ]
}
